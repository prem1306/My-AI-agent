# Copy this file to .env and fill in your# Provider selection
# Examples: 
# provider="gemini", model="gemini/gemini-2.5-flash"
# provider="groq", model="groq/llama3-70b-8192"
# provider="anthropic", model="anthropic/claude-3-5-sonnet-20240620"
# provider="ollama", model="ollama/llama3"
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.5-flash

# API Keys
GOOGLE_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
