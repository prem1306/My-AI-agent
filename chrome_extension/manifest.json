{
    "manifest_version": 3,
    "name": "AI Agent Suite",
    "version": "2.0",
    "description": "Explain, summarize, translate highlighted text + a command center. Powered by Gemini.",
    "permissions": [
        "activeTab",
        "scripting",
        "contextMenus",
        "storage"
    ],
    "host_permissions": [
        "http://localhost:8000/*",
        "http://127.0.0.1:8000/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>", "file://*/*"],
            "js": ["explainer.js", "command_center.js"],
            "all_frames": false
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "AI Agent Suite"
    },
    "icons": {
        "16":  "icons/icon16.png",
        "48":  "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}